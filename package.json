{
    "name": "ballpit-root",
    "version": "1.0.0",
    "description": "Ballpit - Blockchain-Based Shareholder Voting System",
    "scripts": {
        "test": "npm test --prefix backend",
        "test:contract": "npm test --prefix voting_contract",
        "backend": "npm start --prefix backend",
        "frontend": "npm run dev --prefix frontend",
        "test:e2e": "npm run test:e2e --prefix backend",
        "contract:build": "cd voting_contract && anchor build",
        "install-all": "npm install --prefix backend && npm install --prefix frontend && cd voting_contract && npm install"
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    }
}